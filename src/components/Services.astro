---
const services = [
  { number: '01', i18nKey: 'service0' },
  { number: '02', i18nKey: 'service3' },
  { number: '03', i18nKey: 'service1' },
  { number: '04', i18nKey: 'service2' },
];
---

<section class="px-6 py-24 bg-gray-50 dark:bg-neutral-900">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-16 border-b border-gray-200 dark:border-neutral-800 pb-8">
      <h2 class="text-xs font-mono text-gray-500 dark:text-neutral-500 tracking-widest uppercase" data-i18n="services.label">Services</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: statement -->
      <div class="lg:sticky lg:top-24">
        <h3 class="text-4xl md:text-5xl font-black tracking-tighter text-black dark:text-white leading-tight mb-6">
          <span data-i18n="services.headlineLine1">Businesses move faster</span><br />
          <span class="text-gray-500 dark:text-neutral-500" data-i18n="services.headlineLine2">when the repetitive work</span><br />
          <span data-i18n="services.headlineLine3">takes care of itself.</span>
        </h3>
        <p class="text-gray-500 dark:text-neutral-400 leading-relaxed max-w-sm" data-i18n="services.intro">
          Whether through code, AI, or a combination of both — I help teams eliminate the bottlenecks
          that compound over time and quietly drain capacity.
        </p>
      </div>

      <!-- Right: service list -->
      <div class="divide-y divide-gray-200 dark:divide-neutral-800">
        {services.map((service) => (
          <div class="py-8 first:pt-0">
            <div class="flex items-baseline gap-4 mb-3">
              <span class="text-xs font-mono text-gray-500 dark:text-neutral-500 flex-shrink-0">{service.number}</span>
              <h4 class="text-lg font-black tracking-tighter text-black dark:text-white" data-i18n={`services.${service.i18nKey}.title`}>—</h4>
            </div>
            <p class="text-sm text-gray-500 dark:text-neutral-400 leading-relaxed pl-8" data-i18n={`services.${service.i18nKey}.desc`}>—</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
