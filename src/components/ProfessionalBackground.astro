---
const timeline = [
  { period: '11.2025 – Present', company: 'Locon Sp. z.o.o', i18nKey: 'job0' },
  { period: '10.2025 – Present', company: 'CYA Studio',      i18nKey: 'job1' },
  { period: '10.2021 – 11.2025', company: 'Deloitte Digital', i18nKey: 'job2' },
];
---

<section class="px-6 py-24 max-w-7xl mx-auto">
  <div class="flex items-end justify-between mb-16 border-b border-gray-200 dark:border-neutral-800 pb-8">
    <h2 class="text-xs font-mono text-gray-500 dark:text-neutral-500 tracking-widest uppercase" data-i18n="background.label">Professional Background</h2>
    <span class="text-xs font-mono text-gray-500 dark:text-neutral-500" data-i18n="background.count">6 years experience</span>
  </div>

  <div class="divide-y divide-gray-200 dark:divide-neutral-800">
    {timeline.map((entry) => (
      <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-6 py-10">
        <div>
          <span class="text-xs font-mono text-gray-500 dark:text-neutral-500">{entry.period}</span>
        </div>
        <div class="flex flex-col gap-2">
          <div class="flex flex-wrap items-baseline gap-3">
            <h3 class="text-lg font-black tracking-tighter text-black dark:text-white" data-i18n={`background.${entry.i18nKey}.role`}>—</h3>
            <span class="text-sm text-gray-500 dark:text-neutral-500">@ {entry.company}</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-neutral-400 leading-relaxed max-w-2xl" data-i18n={`background.${entry.i18nKey}.desc`}>—</p>
        </div>
      </div>
    ))}
  </div>
</section>
