---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SelectedWork from '../components/SelectedWork.astro';
import Services from '../components/Services.astro';
import TechStack from '../components/TechStack.astro';
import ProfessionalBackground from '../components/ProfessionalBackground.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
  <main>
    <Hero />
    <SelectedWork />
    <Services />
    <TechStack />
    <ProfessionalBackground />
    <Contact />
  </main>

  <footer class="border-t border-gray-200 dark:border-neutral-800 px-6 py-8 max-w-7xl mx-auto">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <span class="text-xs font-mono text-gray-500 dark:text-neutral-500" data-i18n="footer.copyright">© 2025 Karol Liwiński</span>
      <span class="text-xs font-mono text-gray-500 dark:text-neutral-500" data-i18n="footer.tagline">Fullstack Developer — GenAI Specialist</span>
    </div>
  </footer>
</Layout>
