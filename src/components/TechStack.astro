---
const categories = [
  {
    label: 'Frontend',
    items: ['React', 'Next.js', 'Redux Toolkit', 'TypeScript', 'Vitest', 'Playwright'],
  },
  {
    label: 'Backend & Data',
    items: ['Node.js', 'Nest.js', 'Express', 'PostgreSQL', 'GraphQL', 'Python'],
  },
  {
    label: 'GenAI & Workflow',
    items: ['LLM Integration', 'Prompt Engineering', 'Claude Code', 'Cursor', 'OpenAI API'],
  },
  {
    label: 'DevOps',
    items: ['CI/CD', 'Git', 'GCP', 'Docker'],
  },
];
---

<section class="px-6 py-24 bg-white dark:bg-neutral-950">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-16 border-b border-gray-200 dark:border-neutral-800 pb-8">
      <h2 class="text-xs font-mono text-gray-500 dark:text-neutral-500 tracking-widest uppercase" data-i18n="techStack.label">Tech Stack & Expertise</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
      {categories.map((cat) => (
        <div>
          <h3 class="text-xs font-mono text-black dark:text-white tracking-widest uppercase mb-6">{cat.label}</h3>
          <ul class="space-y-3">
            {cat.items.map((item) => (
              <li class="flex items-center gap-3 text-sm text-gray-500 dark:text-neutral-400">
                <span class="w-1 h-1 bg-gray-400 dark:bg-neutral-600 rounded-full flex-shrink-0" aria-hidden="true"></span>
                <span class="font-mono">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
