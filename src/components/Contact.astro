---
---

<section id="contact" class="px-6 py-24 bg-gray-50 dark:bg-neutral-900">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-16 border-b border-gray-200 dark:border-neutral-800 pb-8">
      <h2 class="text-xs font-mono text-gray-500 dark:text-neutral-500 tracking-widest uppercase" data-i18n="contact.label">Contact</h2>
      <span class="text-xs font-mono text-gray-500 dark:text-neutral-500" data-i18n="contact.location">Based in Poland — GMT+1</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <div>
        <h3 class="text-4xl md:text-5xl font-black tracking-tighter text-black dark:text-white leading-tight mb-8">
          <span data-i18n="contact.headlineLine1">Let's build something</span><br />
          <span class="text-gray-500 dark:text-neutral-500" data-i18n="contact.headlineLine2">exceptional together.</span>
        </h3>
        <p class="text-gray-500 dark:text-neutral-400 leading-relaxed max-w-md" data-i18n="contact.intro">
          Open to freelance projects, long-term partnerships and remote collaborations.
          Get in touch and let's talk.
        </p>
      </div>

      <div class="flex flex-col justify-center gap-8">
        <div class="border-b border-gray-200 dark:border-neutral-800 pb-6">
          <p class="text-xs font-mono text-gray-500 dark:text-neutral-500 tracking-widest uppercase mb-2" data-i18n="contact.emailLabel">Email</p>
          <a
            href="mailto:k.liwinski@gmail.com"
            class="text-xl font-medium text-black dark:text-white hover:text-gray-500 dark:hover:text-neutral-400 transition-colors duration-200"
          >
            k.liwinski@gmail.com
          </a>
        </div>

        <div class="border-b border-gray-200 dark:border-neutral-800 pb-6">
          <p class="text-xs font-mono text-gray-500 dark:text-neutral-500 tracking-widest uppercase mb-2" data-i18n="contact.phoneLabel">Phone</p>
          <a
            href="tel:+48513811205"
            class="text-xl font-medium text-black dark:text-white hover:text-gray-500 dark:hover:text-neutral-400 transition-colors duration-200"
          >
            +48 513 811 205
          </a>
        </div>

        <div>
          <p class="text-xs font-mono text-gray-500 dark:text-neutral-500 tracking-widest uppercase mb-4" data-i18n="contact.socialsLabel">Socials</p>
          <div class="flex gap-6">
            <a
              href="https://linkedin.com/in/liwinskikarol"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-mono text-black dark:text-white hover:text-gray-500 dark:hover:text-neutral-400 transition-colors duration-200 underline underline-offset-4"
            >
              LinkedIn
            </a>
            <a
              href="https://github.com/lilivin"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm font-mono text-black dark:text-white hover:text-gray-500 dark:hover:text-neutral-400 transition-colors duration-200 underline underline-offset-4"
            >
              GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
